# Copy to application-local.properties in this directory (gitignored). Use with: -Dspring.profiles.active=local
# Merged: JDBC + email base URL for links + security + mail password (and any other env-only overrides you need).

# PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/paw
spring.datasource.username=pawdbuser
spring.datasource.password=change-me-local

# Public base URL for email CTAs (browser origin, include context path, no trailing slash)
mail.app.base.url=http://localhost:8080/webapp

# JWT signing secret. Optional in the local/test profiles ONLY: if left blank the app boots with a random
# key (tokens reset on restart). Set a fixed value here to keep sessions across restarts during development.
app.security.jwt.secret=local-dev-jwt-secret-change-me

# Gmail / SMTP (JavaMail) — app password, not the account password
mail.server.password=local-mail-not-configured

# Hibernate dev overrides: dump every SQL statement (formatted) to the console. Override the production-safe
# defaults from application.properties. Keep these OFF in application-deployed.properties.
hibernate.show_sql=true
hibernate.format_sql=true
hibernate.use_sql_comments=true

# CORS: enabled only with spring.profiles.active=local (see LocalCorsConfig). Vite/Postman against Jetty.
# Deployed WAR (SPA + /api same-origin) disables CORS — no property needed here beyond the profile.
