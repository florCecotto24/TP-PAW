<?xml version="1.0" encoding="UTF-8"?>
<!--
  Classpath entry for Logback auto-configuration. File appenders and patterns: logback/logback-includes.xml; production loggers: logback/logback-prod.xml.

  Production-style logging: no console (use files only for the app and PAW-specific names).
  Local development with console: -Dlogback.configurationFile=classpath:logback/logback-local.xml
  (see webapp/pom.xml jetty jvmArgs)

  Log directory: -DLOG_DIR=... (default: ./logs under the process working directory).
-->
<configuration>
    <include resource="logback/logback-includes.xml"/>
    <include resource="logback/logback-prod.xml"/>
</configuration>
