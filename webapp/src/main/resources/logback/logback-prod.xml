<?xml version="1.0" encoding="UTF-8"?>
<!-- Production loggers: included from classpath root logback.xml -->
<included>
    <!-- Suppress DEBUG from common frameworks in production. -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.apache" level="WARN"/>
    <logger name="com.zaxxer" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

    <!-- Application code: INFO / WARN / ERROR each to its own daily file (see logback-includes.xml). No DEBUG. -->
    <logger name="ar.edu.itba.paw" level="INFO" additivity="false">
        <appender-ref ref="APP_INFO"/>
        <appender-ref ref="APP_WARN"/>
        <appender-ref ref="APP_ERROR"/>
    </logger>

    <!-- Optional: persistence layer in its own files (uncomment to enable package-specific files). -->
    <!--
    <logger name="ar.edu.itba.paw.persistence" level="INFO" additivity="false">
        <appender-ref ref="APP_INFO"/>
        <appender-ref ref="APP_WARN"/>
        <appender-ref ref="APP_ERROR"/>
    </logger>
    -->

    <!--
      Root: WARN so third-party libraries only emit WARN+; PLATFORM_WARN / PLATFORM_ERROR split by level.
      Application packages use additivity=false so they do not duplicate into platform files.
    -->
    <root level="WARN">
        <appender-ref ref="PLATFORM_WARN"/>
        <appender-ref ref="PLATFORM_ERROR"/>
    </root>
</included>
