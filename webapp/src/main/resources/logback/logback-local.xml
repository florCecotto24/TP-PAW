<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local: rolling files for INFO/WARN like production, plus console with DEBUG for ar.edu.itba.paw.
  Use: -Dlogback.configurationFile=classpath:logback/logback-local.xml
-->
<configuration>
    <include resource="logback/logback-includes.xml"/>

    <property name="CONSOLE_LOG_PATTERN" value="%d{HH:mm:ss.SSS} [PAW] %highlight(%-5level) %cyan(%logger{50}) - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>DEBUG</level>
        </filter>
    </appender>

    <logger name="org.springframework" level="INFO"/>
    <!-- Keep after org.springframework so the ignore-static WARN stays silenced (see logback-includes). -->
    <logger name="org.springframework.security.config.annotation.web.builders.WebSecurity" level="ERROR"/>
    <logger name="org.apache" level="WARN"/>

    <logger name="ar.edu.itba.paw" level="DEBUG" additivity="false">
        <appender-ref ref="APP_INFO"/>
        <appender-ref ref="APP_WARN"/>
        <appender-ref ref="APP_ERROR"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="PLATFORM_WARN"/>
        <appender-ref ref="PLATFORM_ERROR"/>
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
