<?xml version="1.0" encoding="UTF-8"?>
<!-- Shared appenders: included by classpath logback.xml and logback/logback-local.xml -->
<included>
    <!--
      Log directory on disk: JVM -DLOG_DIR=... (default: logs/ under cwd).
      On pampero, set LOG_DIR to the folder exposed as http://pawserver.it.itba.edu.ar/logs/ so files appear as e.g.
      paw-2026a-08-webapp-info.*.log, -warn.-, -error.-, -platform-warn.-, -platform-error.- (Logback writes files only).
    -->
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>
    <property name="LOG_BASENAME" value="${LOG_BASENAME:-paw}"/>
    <property name="DEPLOY_LOG_BASENAME" value="${DEPLOY_LOG_BASENAME:-paw-2026a-08-webapp}"/>
    <!-- Prefix in pattern only; do not repeat in log message text in Java. -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [PAW] [%thread] %-5level %logger{50} - %msg%n"/>

    <!-- App (ar.edu.itba.paw): INFO-only → ${DEPLOY_LOG_BASENAME}-info.yyyy-MM-dd.log -->
    <appender name="APP_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <append>true</append>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${DEPLOY_LOG_BASENAME}-info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- App: WARN only -->
    <appender name="APP_WARN" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <append>true</append>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${DEPLOY_LOG_BASENAME}-warn.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- App: ERROR only -->
    <appender name="APP_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <append>true</append>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${DEPLOY_LOG_BASENAME}-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- Frameworks / libraries: WARN only → ${DEPLOY_LOG_BASENAME}-platform-warn.yyyy-MM-dd.log -->
    <appender name="PLATFORM_WARN" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <append>true</append>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [PAW-PLATFORM] [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${DEPLOY_LOG_BASENAME}-platform-warn.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>512MB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!--
      Silence the false-positive warning emitted once per ignored pattern by
      org.springframework.security.config.annotation.web.builders.WebSecurity when WebAuthConfig
      registers WebSecurityCustomizer#ignoring(...). The trade-off (no SecurityContext / no headers
      on static assets) is intentional and documented at the call site.
      See: https://github.com/spring-projects/spring-security/issues/10938
    -->
    <logger name="org.springframework.security.config.annotation.web.builders.WebSecurity" level="ERROR"/>

    <!-- Frameworks / libraries: ERROR only -->
    <appender name="PLATFORM_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <append>true</append>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [PAW-PLATFORM] [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${DEPLOY_LOG_BASENAME}-platform-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>512MB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

</included>
