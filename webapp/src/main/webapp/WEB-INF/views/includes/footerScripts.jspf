<%-- Bootstrap JS, Flatpickr, app scripts (without visual footer). Include before </body>. --%>
<%@ taglib prefix="spring" uri="http://www.springframework.org/tags" %>
<%@ taglib prefix="c"      uri="http://java.sun.com/jsp/jstl/core" %>
<spring:eval expression="T(org.springframework.context.i18n.LocaleContextHolder).getLocale().getLanguage()"
             var="fpLocale"/>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<c:if test="${fpLocale == 'es'}">
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
<script>flatpickr.localize(flatpickr.l10ns.es);</script>
</c:if>
<script src="${pageContext.request.contextPath}/js/components.js"></script>
<script src="${pageContext.request.contextPath}/js/ownerCalendar.js"></script>
<script src="${pageContext.request.contextPath}/js/price-market-insight.js"></script>
