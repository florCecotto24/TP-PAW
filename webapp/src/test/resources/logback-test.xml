<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: use Logback/SLF4J (ConsoleAppender), not System.out. Prefix [PAW] matches main pattern style. -->
<configuration>
    <property name="defaultPattern" value="%d{HH:mm:ss.SSS} [PAW] [%thread] %highlight(%-5level) %cyan(%logger{36}) - %msg%n" />
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${defaultPattern}</pattern>
        </encoder>
    </appender>
    <!--
      Same intentional ignore as runtime (WebAuthConfig + cátedra OK for /public|/assets).
      Contained in logback-includes.xml for Jetty/prod; tests use this file alone.
    -->
    <logger name="org.springframework.security.config.annotation.web.builders.WebSecurity" level="ERROR"/>
    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>